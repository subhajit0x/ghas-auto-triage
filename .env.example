# LLM (OpenAI-compatible)
OPENAI_API_KEY=sk-...

# GitHub — PAT with security_events + contents on target repos
GHAS_TRIAGE_GITHUB_TOKEN=github_pat_...
# Fallback names also supported:
# GHAS_LLM_GITHUB_TOKEN=
# GITHUB_TOKEN=

# Jira (direct — simplest path)
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=...

# Optional: AWS Secrets Manager for Jira JSON {"email","token"}
# JIRA_SECRET_NAME=your-org/jira/ghas-triage
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Optional: clone private repos for context
# ORG_SSH_KEY_PATH=/path/to/deploy_key

# Optional: Slack (enable in ghas_llm.yaml)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Runtime
GHAS_LLM_CONFIG=./ghas_llm.yaml
GHAS_LLM_DRY_RUN=false
